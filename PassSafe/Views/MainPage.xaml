<?xml version="1.0" encoding="UTF-8" ?>
<TabbedPage x:Class="PassSafe.Views.MainPage"
            xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:d="http://schemas.microsoft.com/dotnet/2021/maui/design" xmlns:droid="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.AndroidSpecific;assembly=Microsoft.Maui.Controls" xmlns:local="clr-namespace:PassSafe" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons" xmlns:vw="clr-namespace:PassSafe.Views"
            Title="PassSafe"
            droid:TabbedPage.ToolbarPlacement="Bottom"
            SelectedTabColor="{DynamicResource Primary}"
            mc:Ignorable="d">
    <vw:SafePage mi:MauiIcon.Value="{mi:MaterialSharp Icon=Shield}" NavigationPage.HasNavigationBar="{OnPlatform Android=False, Default=True}" />
    <vw:PassGeneratorPage mi:MauiIcon.Value="{mi:MaterialSharp Icon=Password}" />
    <vw:PassAnalyzerPage mi:MauiIcon.Value="{mi:MaterialSharp Icon=Analytics}" />
    <vw:SettingsPage mi:MauiIcon.Value="{mi:MaterialSharp Icon=Settings}" />
</TabbedPage>
