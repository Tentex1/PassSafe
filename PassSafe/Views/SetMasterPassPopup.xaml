<?xml version="1.0" encoding="utf-8" ?>
<mopups:PopupPage x:Class="PassSafe.Views.SetMasterPassPopup"
                  xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups" xmlns:viewmodels="clr-namespace:PassSafe.ViewModels"
                  x:DataType="viewmodels:SetMasterPassViewModel" BackgroundColor="#B3000000" CloseWhenBackgroundIsClicked="False" NavigationPage.HasNavigationBar="False">

    <Border BackgroundColor="{AppThemeBinding Dark=#181818,
                                              Light=#FAF9F6}"
            HorizontalOptions="Center" StrokeShape="RoundRectangle 12" StrokeThickness="0" VerticalOptions="Center">
        <Border.Resources>
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{AppThemeBinding Dark=#FAF9F6, Light=#1C1917}" />
            </Style>
        </Border.Resources>
        <Border.WidthRequest>
            <OnIdiom Default="350" Desktop="500" />
        </Border.WidthRequest>

        <VerticalStackLayout Padding="20" Spacing="15">
            <Label FontAttributes="Bold" FontSize="20" HorizontalOptions="Center"
                   Text="{Binding TitleText}" />

            <Entry IsPassword="True" Placeholder="Ana Şifre"
                   Text="{Binding MasterPass}"
                   WidthRequest="250" />

            <Entry IsPassword="True"
                   IsVisible="{Binding IsRepeatVisible}"
                   Placeholder="Ana Şifre (Tekrar)"
                   Text="{Binding MasterPassRepeat}"
                   WidthRequest="250" />

            <Button Margin="0,10,0,0"
                    Command="{Binding ProcessActionCommand}"
                    HeightRequest="45"
                    Text="{Binding ButtonText}"
                    WidthRequest="250" />
        </VerticalStackLayout>
    </Border>
</mopups:PopupPage>