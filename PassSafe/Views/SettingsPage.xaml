<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="PassSafe.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons" xmlns:viewmodels="clr-namespace:PassSafe.ViewModels"
             Title="Ayarlar"
             x:DataType="viewmodels:SettingsViewModel"
             BindingContext="{Binding SettingsViewModel, Source={StaticResource VMLocator}}">

    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="{AppThemeBinding Dark=#E2E8F0, Light=#1e293b}" />
        </Style>
        <Style TargetType="Picker">
            <Setter Property="TextColor" Value="{DynamicResource Primary}" />
            <Setter Property="TitleColor" Value="Gray" />
        </Style>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Dark=#1E1E1E, Light=#FFFFFF}" />
            <Setter Property="Stroke" Value="{AppThemeBinding Dark=#333333, Light=#E2E8F0}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="15,10" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Margin="15,10,15,30" Spacing="25">

            <Label FontAttributes="Bold" FontSize="28" Text="Ayarlar" />

            <VerticalStackLayout Spacing="8">
                <Label Margin="5,0,0,0"
                       FontAttributes="Bold" FontSize="12" Text="GÜVENLİK" TextColor="Gray" />
                <VerticalStackLayout Spacing="10">

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <mi:MauiIcon Grid.Column="0"
                                         Margin="0,0,15,0"
                                         Icon="{mi:MaterialSharp Icon=Password}"
                                         IconColor="{DynamicResource Primary}"
                                         IconSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label FontAttributes="Bold" FontSize="15" Text="Ana Şifreyi Değiştir" />
                                <Label FontSize="12" Text="Kasanıza giriş şifrenizi güncelleyin" TextColor="Gray" />
                            </VerticalStackLayout>
                            <mi:MauiIcon Grid.Column="2"
                                         Icon="{mi:MaterialSharp Icon=ChevronRight}"
                                         IconColor="Gray" IconSize="24" VerticalOptions="Center" />
                        </Grid>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ChangeMasterPasswordCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <mi:MauiIcon Grid.Column="0"
                                         Margin="0,0,15,0"
                                         Icon="{mi:MaterialSharp Icon=Timer}"
                                         IconColor="{DynamicResource Primary}"
                                         IconSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label FontAttributes="Bold" FontSize="15" Text="Otomatik Kilitleme" />
                                <Label FontSize="12" Text="Uygulama arka plana atıldığında kilitlensin" TextColor="Gray" />
                            </VerticalStackLayout>
                            <Picker Grid.Column="2"
                                    HorizontalOptions="End"
                                    SelectedItem="{Binding AutoLockTime}"
                                    VerticalOptions="Center" WidthRequest="120">
                                <Picker.Items>
                                    <x:String>Anında</x:String>
                                    <x:String>1 Dakika</x:String>
                                    <x:String>5 Dakika</x:String>
                                    <x:String>Asla</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <mi:MauiIcon Grid.Column="0"
                                         Margin="0,0,15,0"
                                         Icon="{mi:MaterialSharp Icon=ContentPasteOff}"
                                         IconColor="{DynamicResource Primary}"
                                         IconSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label FontAttributes="Bold" FontSize="15" Text="Panoyu Temizle" />
                                <Label FontSize="12" Text="Kopyalanan şifreyi hafızadan siler" TextColor="Gray" />
                            </VerticalStackLayout>
                            <Picker Grid.Column="2"
                                    HorizontalOptions="End"
                                    SelectedItem="{Binding ClipboardClearTime}"
                                    VerticalOptions="Center" WidthRequest="120">
                                <Picker.Items>
                                    <x:String>15 Saniye</x:String>
                                    <x:String>30 Saniye</x:String>
                                    <x:String>1 Dakika</x:String>
                                    <x:String>Kapat</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Margin="5,0,0,0"
                       FontAttributes="Bold" FontSize="12" Text="GÖRÜNÜM VE DİL" TextColor="Gray" />
                <VerticalStackLayout Spacing="10">

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <mi:MauiIcon Grid.Column="0"
                                         Margin="0,0,15,0"
                                         Icon="{mi:MaterialSharp Icon=DarkMode}"
                                         IconColor="{DynamicResource Primary}"
                                         IconSize="24" VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   FontAttributes="Bold" FontSize="15" Text="Tema" VerticalOptions="Center" />
                            <Picker Grid.Column="2"
                                    HorizontalOptions="End"
                                    SelectedItem="{Binding SelectedTheme}"
                                    VerticalOptions="Center" WidthRequest="120">
                                <Picker.Items>
                                    <x:String>Sistem</x:String>
                                    <x:String>Açık</x:String>
                                    <x:String>Koyu</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <mi:MauiIcon Grid.Column="0"
                                         Margin="0,0,15,0"
                                         Icon="{mi:MaterialSharp Icon=Language}"
                                         IconColor="{DynamicResource Primary}"
                                         IconSize="24" VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   FontAttributes="Bold" FontSize="15" Text="Uygulama Dili" VerticalOptions="Center" />
                            <Picker Grid.Column="2"
                                    HorizontalOptions="End" SelectedIndex="1" VerticalOptions="Center" WidthRequest="120">
                                <Picker.Items>
                                    <x:String>English</x:String>
                                    <x:String>Türkçe</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Margin="5,0,0,0"
                       FontAttributes="Bold" FontSize="12" Text="VERİ YÖNETİMİ (YEDEKLEME)" TextColor="Gray" />
                <VerticalStackLayout Spacing="10">

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <mi:MauiIcon Grid.Column="0"
                                         Margin="0,0,15,0"
                                         Icon="{mi:MaterialSharp Icon=CloudUpload}"
                                         IconColor="{DynamicResource Primary}"
                                         IconSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label FontAttributes="Bold" FontSize="15" Text="Yedekleme İçe Aktar (.sqlite)" />
                                <Label FontSize="12" Text="Eski kasanızı cihaza yükleyin" TextColor="Gray" />
                            </VerticalStackLayout>
                            <mi:MauiIcon Grid.Column="2"
                                         Icon="{mi:MaterialSharp Icon=ChevronRight}"
                                         IconColor="Gray" IconSize="24" VerticalOptions="Center" />
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ImportDatabaseCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <mi:MauiIcon Grid.Column="0"
                                         Margin="0,0,15,0"
                                         Icon="{mi:MaterialSharp Icon=CloudDownload}"
                                         IconColor="{DynamicResource Primary}"
                                         IconSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label FontAttributes="Bold" FontSize="15" Text="Mevcut Veritabanını Dışa Aktar" />
                                <Label FontSize="12" Text="Verilerinizi güvenli bir yere yedekleyin" TextColor="Gray" />
                            </VerticalStackLayout>
                            <mi:MauiIcon Grid.Column="2"
                                         Icon="{mi:MaterialSharp Icon=ChevronRight}"
                                         IconColor="Gray" IconSize="24" VerticalOptions="Center" />
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ExportDatabaseCommand}" />
                        </Border.GestureRecognizers>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>