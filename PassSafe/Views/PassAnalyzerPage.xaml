<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="PassSafe.Views.PassAnalyzerPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:PassSafe.Converters" xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons" xmlns:viewmodels="clr-namespace:PassSafe.ViewModels"
             Title="İstatistikler"
             BindingContext="{Binding PassAnalyzerViewModel, Source={StaticResource VMLocator}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringToIconConverter x:Key="IconConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <RefreshView Command="{Binding RunAnalysisCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="25">

                <Button mi:MauiIcon.Value="{mi:MaterialSharp Icon=Refresh}"
                        BackgroundColor="{DynamicResource Primary}"
                        Command="{Binding RunAnalysisCommand}"
                        CornerRadius="8" FontAttributes="Bold" HeightRequest="40" HorizontalOptions="End" Text="Analizi Yenile" TextColor="White">
                    <Button.IsVisible>
                        <OnIdiom x:TypeArguments="x:Boolean" Default="False" Desktop="True" />
                    </Button.IsVisible>
                </Button>

                <Border Stroke="{DynamicResource Primary}"
                        StrokeShape="RoundRectangle 16" StrokeThickness="1">
                    <VerticalStackLayout Padding="20,30,20,30"
                                         HorizontalOptions="Center" Spacing="15">

                        <Grid HeightRequest="160" HorizontalOptions="Center" WidthRequest="160">
                            <Ellipse Stroke="#252525" StrokeThickness="16" />
                            <Ellipse Rotation="-90"
                                     Stroke="{DynamicResource Primary}"
                                     StrokeDashArray="3.5, 2" StrokeThickness="16" />

                            <VerticalStackLayout HorizontalOptions="Center" Spacing="-5" VerticalOptions="Center">
                                <Label FontAttributes="Bold" FontSize="36" HorizontalOptions="Center"
                                       Text="{Binding SecurityScore, StringFormat='%{0}'}"
                                       TextColor="{DynamicResource Primary}" />
                                <Label CharacterSpacing="2" FontAttributes="Bold" FontSize="10" HorizontalOptions="Center" Text="SKOR" TextColor="#888888" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Margin="0,10,0,0" Spacing="5">
                            <Label FontAttributes="Bold" FontSize="18" HorizontalOptions="Center"
                                   Text="{Binding GeneralStatusText, StringFormat='Genel Durum: {0}'}"
                                   TextColor="White" />

                            <Label FontSize="15" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="WordWrap"
                                   Text="{Binding GeneralStatusDescription}"
                                   TextColor="{AppThemeBinding Dark=#A0A0A0,
                                                               Light=Black}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="10">
                    <Label Margin="0,0,0,5"
                           FontAttributes="Bold" FontSize="12" Text="ÖZET ANALİZ" TextColor="#B0B0B0" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding AnalysisCards}" Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#222222" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                                    <Grid ColumnDefinitions="4, *, Auto">

                                        <BoxView Grid.Column="0" BackgroundColor="{Binding SideColor}" />

                                        <VerticalStackLayout Grid.Column="1"
                                                             Padding="15,15,0,15"
                                                             Spacing="4" VerticalOptions="Center">
                                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                <mi:MauiIcon Icon="{Binding IconKey, Converter={StaticResource IconConverter}}"
                                                             IconColor="{Binding SideColor}"
                                                             IconSize="16" VerticalOptions="Center" />
                                                <Label FontAttributes="Bold" FontSize="14"
                                                       Text="{Binding Title}"
                                                       TextColor="White" VerticalOptions="Center" />
                                            </HorizontalStackLayout>

                                            <Label FontSize="12"
                                                   Text="{Binding Description}"
                                                   TextColor="#A0A0A0" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2"
                                               Margin="0,0,20,0"
                                               FontAttributes="Bold" FontSize="22"
                                               Text="{Binding Count}"
                                               TextColor="{Binding SideColor}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Grid Margin="0,5,0,5" ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               FontAttributes="Bold" FontSize="12" Text="KRİTİK EYLEMLER" TextColor="#B0B0B0" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="12" Text="! Hemen Düzeltin" TextColor="#FF8A8A" VerticalOptions="Center" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding CriticalActions}" Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#1E1E1E"
                                        Stroke="{Binding Color}"
                                        StrokeShape="RoundRectangle 12" StrokeThickness="0.5">
                                    <Grid Padding="12"
                                          ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

                                        <Border Grid.Column="0"
                                                BackgroundColor="#2A2A2A" HeightRequest="45" StrokeShape="RoundRectangle 8" StrokeThickness="0" WidthRequest="45">
                                            <mi:MauiIcon HorizontalOptions="Center"
                                                         Icon="{Binding IconKey, Converter={StaticResource IconConverter}}"
                                                         IconColor="{Binding Color}"
                                                         IconSize="20" VerticalOptions="Center" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2" VerticalOptions="Center">
                                            <Label FontAttributes="Bold" FontSize="14" LineBreakMode="TailTruncation"
                                                   Text="{Binding Title}"
                                                   TextColor="White" />
                                            <Label FontSize="11" LineBreakMode="TailTruncation"
                                                   Text="{Binding Description}"
                                                   TextColor="#A0A0A0" />
                                        </VerticalStackLayout>

                                        <Button Grid.Column="2"
                                                Padding="12,0"
                                                BackgroundColor="#52FFB8"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PassAnalyzerViewModel}}, Path=ChangePasswordCommand}"
                                                CommandParameter="{Binding TargetPassword}"
                                                CornerRadius="16" FontAttributes="Bold" FontSize="12" HeightRequest="32" Text="Değiştir" TextColor="#121212" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>