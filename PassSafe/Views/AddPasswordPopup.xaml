<?xml version="1.0" encoding="utf-8" ?>
<mopups:PopupPage x:Class="PassSafe.Views.AddPasswordPopup"
                  xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons" xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups" xmlns:viewmodels="clr-namespace:PassSafe.ViewModels"
                  x:DataType="viewmodels:AddPasswordViewModel" BackgroundColor="#B3000000"
                  BindingContext="{Binding AddPasswordViewModel, Source={StaticResource VMLocator}}"
                  NavigationPage.HasNavigationBar="False">

    <Border Margin="0,20,0,20"
            BackgroundColor="{AppThemeBinding Dark=#181818,
                                              Light=#FAF9F6}"
            HorizontalOptions="Center" StrokeShape="RoundRectangle 12" StrokeThickness="0">
        <Border.Resources>
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{AppThemeBinding Dark=#FAF9F6, Light=#1C1917}" />
            </Style>
        </Border.Resources>

        <Border.WidthRequest>
            <OnIdiom Default="350" Desktop="500" />
        </Border.WidthRequest>
        <Border.VerticalOptions>
            <OnIdiom Default="End" Desktop="Center" />
        </Border.VerticalOptions>

        <VerticalStackLayout Padding="15" Spacing="12">

            <Label Padding="0,10,0,0"
                   FontAttributes="Bold" FontSize="20" HorizontalOptions="Center"
                   Text="{Binding PopupTitle}" />

            <!--  İKON SEÇİCİ  -->
            <Border HeightRequest="75" StrokeShape="RoundRectangle 20" StrokeThickness="0">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">

                    <Button mi:MauiIcon.Value="{mi:MaterialSharp Icon=ArrowBackIosNew,
                                                                 IconSize=20,
                                                                 IconColor=White}"
                            BackgroundColor="{DynamicResource Primary}"
                            Command="{Binding PreviousCommand}"
                            CornerRadius="10" HeightRequest="40" WidthRequest="40" />

                    <Border Background="#181830" StrokeShape="RoundRectangle 20" StrokeThickness="0" WidthRequest="70">
                        <mi:MauiIcon Padding="10,5,0,5"
                                     BackgroundColor="#181830"
                                     Icon="{Binding CurrentIcon.Icon}"
                                     IconColor="{StaticResource White}"
                                     IconSize="50" />
                    </Border>

                    <Button mi:MauiIcon.Value="{mi:MaterialSharp Icon=ArrowForwardIos,
                                                                 IconSize=20,
                                                                 IconColor=White}"
                            BackgroundColor="{DynamicResource Primary}"
                            Command="{Binding NextCommand}"
                            CornerRadius="10" HeightRequest="40" WidthRequest="40" />
                </HorizontalStackLayout>
            </Border>

            <!--  KATEGORİ SEÇİM ALANI (Border kaldırıldı)  -->
            <Picker Title="Kategori Seç"
                    ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory}"
                    TextColor="{AppThemeBinding Dark=White,
                                                Light=Black}" />

            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                <Entry Grid.Column="0"
                       Placeholder="Veya yeni kategori yaz..."
                       Text="{Binding NewCategoryName}"
                       TextColor="{AppThemeBinding Dark=White,
                                                   Light=Black}" />

                <Button Grid.Column="1"
                        Padding="15,0"
                        BackgroundColor="{DynamicResource Primary}"
                        Command="{Binding AddNewCategoryCommand}"
                        CornerRadius="8" FontAttributes="Bold" Text="Ekle" TextColor="White" />
            </Grid>

            <!--  GİRİŞLER (Borderlar kaldırıldı)  -->
            <Entry Keyboard="Plain" Placeholder="Şifre Başlığı (Örn: Google)"
                   Text="{Binding Title, Mode=TwoWay}"
                   TextColor="{AppThemeBinding Dark=White,
                                               Light=Black}" />

            <Entry Keyboard="Plain" Placeholder="Kullanıcı Adı veya E-Posta"
                   Text="{Binding UserName, Mode=TwoWay}"
                   TextColor="{AppThemeBinding Dark=White,
                                               Light=Black}" />

            <Entry IsPassword="True" Keyboard="Plain" Placeholder="Şifreniz"
                   Text="{Binding Password}"
                   TextColor="{AppThemeBinding Dark=White,
                                               Light=Black}" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                <Label FontSize="13" Text="Güvenlik:" VerticalOptions="Center" />
                <ProgressBar Progress="{Binding SecurityProgress}"
                             ProgressColor="{Binding SecurityColor}"
                             VerticalOptions="Center" WidthRequest="60" />
                <Label FontAttributes="Bold" FontSize="13"
                       Text="{Binding SecurityStatus}"
                       TextColor="{Binding SecurityColor}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Button Margin="0,5,0,5"
                    BackgroundColor="{DynamicResource Primary}"
                    Command="{Binding AddPasswordCommand}"
                    CornerRadius="8" FontAttributes="Bold"
                    Text="{Binding ActionButtonText}"
                    TextColor="White" />
        </VerticalStackLayout>
    </Border>
</mopups:PopupPage>