<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="PassSafe.Views.SafeView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:micons="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols" xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" xmlns:uranium="clr-namespace:UraniumUI.Material.Controls;assembly=UraniumUI.Material"
             BindingContext="{Binding SafeViewModel, Source={StaticResource VMLocator}}">

    <ContentView.Resources>
        <Style TargetType="ImageButton">
            <Setter Property="Padding" Value="5" />
        </Style>
    </ContentView.Resources>

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0"
              Margin="15,15,15,0"
              ColumnDefinitions="*, Auto">

            <ScrollView Grid.Column="0"
                        HorizontalScrollBarVisibility="Never" Orientation="Horizontal" VerticalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="10">
                    <Button StyleClass="FilledButton" Text="Hepsi" />
                    <Button StyleClass="FilledButton" Text="Son Kullanılanlar" />
                    <Button StyleClass="FilledButton" Text="Favoriler" />
                    <Button StyleClass="FilledButton" Text="Sosyal Medya" />
                </HorizontalStackLayout>
            </ScrollView>

            <uranium:ButtonView Grid.Column="1"
                                Margin="10,0,0,0"
                                HeightRequest="50" HorizontalOptions="End" StyleClass="FilledButton"
                                TappedCommand="{Binding ShowAddPasswordPopupCommand}"
                                VerticalOptions="Center" WidthRequest="50">
                <Image HorizontalOptions="Center" VerticalOptions="Center">
                    <Image.Source>
                        <FontImageSource FontFamily="MaterialSharp"
                                         Glyph="{x:Static micons:MaterialSharp.Add}"
                                         Size="48" />
                    </Image.Source>
                </Image>
            </uranium:ButtonView>
        </Grid>

        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView Grid.Row="1"
                            Margin="20"
                            ItemsSource="{Binding Passwords}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="10" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Execute">
                                    <SwipeItemView Margin="2"
                                                   Command="{Binding SafeViewModel.DeletePasswordCommand, Source={StaticResource VMLocator}}"
                                                   CommandParameter="{Binding Id}">
                                        <uranium:ButtonView Margin="5,0,5,0">
                                            <ImageButton>
                                                <ImageButton.Source>
                                                    <FontImageSource FontFamily="MaterialSharp"
                                                                     Glyph="{x:Static micons:MaterialSharp.Delete}"
                                                                     Color="White" />
                                                </ImageButton.Source>
                                            </ImageButton>
                                        </uranium:ButtonView>
                                    </SwipeItemView>
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border StrokeShape="RoundRectangle 20">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Border Grid.Column="0"
                                            Margin="5,5,5,5"
                                            StrokeShape="RoundRectangle 20" StrokeThickness="0">
                                        <Image Background="#181830" HeightRequest="80" WidthRequest="80">
                                            <Image.Source>
                                                <FontImageSource FontFamily="MaterialSharp"
                                                                 Glyph="{Binding Icon}"
                                                                 Size="48"
                                                                 Color="{AppThemeBinding Dark=White,
                                                                                         Light=White}" />
                                            </Image.Source>
                                        </Image>
                                    </Border>

                                    <Border Grid.Column="1" StrokeThickness="0">
                                        <VerticalStackLayout Margin="0,0,10,0" VerticalOptions="Center">

                                            <Label FontAttributes="Bold" Text="{Binding Title}" />
                                            <Label Text="{Binding UserName}" />
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="Security" />
                                                <ProgressBar Progress="{Binding SecurityProgress}" WidthRequest="40" />
                                                <Label Text="{Binding SecurityStatus}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>

                                    <HorizontalStackLayout Grid.Column="2"
                                                           Margin="0,0,15,0"
                                                           Spacing="3">
                                        <ImageButton Command="{Binding SafeViewModel.ShowPasswordCommand, Source={StaticResource VMLocator}}"
                                                     CommandParameter="{Binding EncryptedPassword}"
                                                     HeightRequest="45">
                                            <ImageButton.Source>
                                                <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static micons:MaterialSharp.Visibility}" />
                                            </ImageButton.Source>
                                        </ImageButton>
                                        <ImageButton Command="{Binding SafeViewModel.CopyPasswordCommand, Source={StaticResource VMLocator}}"
                                                     CommandParameter="{Binding EncryptedPassword}"
                                                     HeightRequest="45">
                                            <ImageButton.Source>
                                                <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static micons:MaterialSharp.Content_copy}" />
                                            </ImageButton.Source>
                                        </ImageButton>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentView>