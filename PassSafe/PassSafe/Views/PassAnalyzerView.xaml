<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="PassSafe.Views.PassAnalyzerView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons" xmlns:models="clr-namespace:PassSafe.Models" xmlns:viewmodels="clr-namespace:PassSafe.ViewModels" xmlns:views="clr-namespace:PassSafe.Views"
             BindingContext="{Binding PassAnalyzerViewModel, Source={StaticResource VMLocator}}"
             Loaded="PassAnalyzer_Loaded">

    <RefreshView Command="{Binding RunAnalysisCommand}" IsRefreshing="{Binding IsRefreshing}">
        <Grid Padding="0,0,0,20"
              RowDefinitions="Auto,Auto,Auto" RowSpacing="5">

            <Grid Grid.Row="0"
                  Margin="15"
                  ColumnDefinitions="Auto,*">

                <Border Grid.Column="0"
                        BackgroundColor="#1E1E1E" StrokeShape="RoundRectangle 20" StrokeThickness="0">
                    <VerticalStackLayout Padding="0,0,0,15" HorizontalOptions="Center">
                        <Border Margin="15"
                                BackgroundColor="Transparent" HeightRequest="150" Stroke="#107C41" StrokeThickness="8" WidthRequest="150">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="75" />
                            </Border.StrokeShape>
                            <Grid HorizontalOptions="Center" VerticalOptions="Center">
                                <Label FontAttributes="Bold" FontSize="28" HorizontalOptions="Center"
                                       Text="{Binding SecurityScore, StringFormat='%{0}'}"
                                       TextColor="White" />
                                <Label Margin="0,35,0,0"
                                       FontSize="10" HorizontalOptions="Center" Text="SKOR" TextColor="Gray" />
                            </Grid>
                        </Border>
                        <Label FontAttributes="Bold" FontSize="19" HorizontalOptions="Center"
                               Text="{Binding GeneralStatusText}"
                               TextColor="White" />
                        <Label Margin="20,5,20,0"
                               FontSize="14" HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               Text="{Binding GeneralStatusDescription}"
                               TextColor="#999999" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     BindableLayout.ItemsSource="{Binding AnalysisCards}"
                                     Spacing="10">

                    <Label Margin="0,0,0,5"
                           FontAttributes="Bold" FontSize="14" Text="ÖZET ANALİZ" TextColor="White" />

                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    BackgroundColor="#222222" HeightRequest="110" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="6, *">
                                    <BoxView Grid.Column="0" Color="{Binding SideColor}" />
                                    <Grid Grid.Column="1"
                                          Padding="16,12"
                                          ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, *">
                                        <mi:MauiIcon Icon="{Binding IconKey}"
                                                     IconColor="{Binding SideColor}"
                                                     IconSize="24" />
                                        <Label Grid.Row="0" Grid.Column="1"
                                               FontAttributes="Bold" FontSize="22"
                                               Text="{Binding Count}"
                                               TextColor="{Binding SideColor}"
                                               VerticalOptions="Center" />
                                        <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Margin="0,8,0,0"
                                               FontAttributes="Bold" FontSize="16"
                                               Text="{Binding Title}"
                                               TextColor="White" />
                                        <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                               Margin="0,4,0,0"
                                               FontSize="13" LineBreakMode="WordWrap"
                                               Text="{Binding Description}"
                                               TextColor="#999999" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Grid.Row="2"
                                 Margin="15,15,15,0"
                                 Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0"
                           FontAttributes="Bold" Text="KRİTİK EYLEMLER" TextColor="White" VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           FontAttributes="Bold" FontSize="13" Text="! Hemen Düzeltin" TextColor="#FF5252" VerticalOptions="Center" />
                </Grid>

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding CriticalActions}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="12"
                                    BackgroundColor="#1E1E1E" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <mi:MauiIcon Grid.Column="0"
                                                 Margin="0,0,12,0"
                                                 Icon="{Binding IconKey}"
                                                 IconColor="{Binding Color}"
                                                 IconSize="24" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label FontAttributes="Bold" FontSize="14"
                                               Text="{Binding Title}"
                                               TextColor="White" />
                                        <Label Margin="0,2,0,0"
                                               FontSize="12"
                                               Text="{Binding Description}"
                                               TextColor="#999999" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="2"
                                            Padding="10,0"
                                            BackgroundColor="#20E19B" CornerRadius="15" HeightRequest="30" Text="Değiştir" TextColor="Black" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

        </Grid>
        <!--</ScrollView>-->
    </RefreshView>
</ContentView>