<?xml version="1.0" encoding="utf-8" ?>
<mopups:PopupPage x:Class="PassSafe.Views.AddPasswordPopup"
                  xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons" xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups"
                  BackgroundColor="#B3000000"
                  BindingContext="{Binding AddPasswordViewModel, Source={StaticResource VMLocator}}"
                  NavigationPage.HasNavigationBar="False">

    <Border Margin="0,20,0,20"
            BackgroundColor="{AppThemeBinding Dark=#181818,
                                              Light=#FAF9F6}"
            HorizontalOptions="Center" StrokeShape="RoundRectangle 12" StrokeThickness="0">
        <Border.Resources>
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{AppThemeBinding Dark=#FAF9F6, Light=#1C1917}" />
            </Style>
        </Border.Resources>

        <Border.WidthRequest>
            <OnIdiom Default="350" Desktop="500" />
        </Border.WidthRequest>

        <Border.VerticalOptions>
            <OnIdiom Default="End" Desktop="Center" />
        </Border.VerticalOptions>

        <VerticalStackLayout Padding="10" Spacing="15">
            <Label Padding="0,15,0,0"
                   FontSize="20" HorizontalOptions="Center" Text="Şifre Ekle" />

            <Border HeightRequest="75" StrokeShape="RoundRectangle 20" StrokeThickness="0">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                    <ImageButton mi:MauiIcon.Value="{mi:MaterialSharp Icon=ArrowBackIosNew,
                                                                      IconColor={AppThemeBinding Dark={StaticResource White},
                                                                                                 Light={StaticResource Gray950}}}"
                                 Command="{Binding PreviousCommand}"
                                 CornerRadius="40" HeightRequest="40" />
                    <Border Margin="5"
                            Background="#181830" StrokeShape="RoundRectangle 20" StrokeThickness="0" WidthRequest="70">
                        <mi:MauiIcon HorizontalOptions="Center"
                                     Icon="{Binding CurrentIcon.Icon}"
                                     IconColor="{StaticResource White}"
                                     VerticalOptions="Center" />
                    </Border>
                    <ImageButton mi:MauiIcon.Value="{mi:MaterialSharp Icon=ArrowForwardIos,
                                                                      IconColor={AppThemeBinding Dark={StaticResource White},
                                                                                                 Light={StaticResource Gray950}}}"
                                 Command="{Binding NextCommand}"
                                 CornerRadius="40" HeightRequest="40" />
                </HorizontalStackLayout>
            </Border>

            <Entry Keyboard="Plain" Placeholder="Password Title (ex. Google Account)"
                   Text="{Binding Title, Mode=TwoWay}" />

            <Entry Keyboard="Plain" Placeholder="Email or Username (ex. qwerty123@gmail.com)"
                   Text="{Binding UserName, Mode=TwoWay}" />

            <Entry IsPassword="True" Keyboard="Plain" Placeholder="Password"
                   Text="{Binding Password}" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Security" />
                <ProgressBar Progress="{Binding SecurityProgress}" WidthRequest="40" />
                <Label Text="{Binding SecurityStatus}" />
            </HorizontalStackLayout>

            <Button Margin="15,0,15,15"
                    Command="{Binding AddPasswordCommand}"
                    StyleClass="FilledButton" Text="Ekle" />
        </VerticalStackLayout>
    </Border>
</mopups:PopupPage>