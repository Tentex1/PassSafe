<?xml version="1.0" encoding="utf-8" ?>
<mopups:PopupPage x:Class="PassSafe.Views.AddPasswordPopup"
                  xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups" xmlns:uranium="clr-namespace:UraniumUI.Material.Controls;assembly=UraniumUI.Material"
                  BackgroundColor="#B3000000"
                  BindingContext="{Binding AddPasswordViewModel, Source={StaticResource VMLocator}}">

    <Border BackgroundColor="{AppThemeBinding Dark=#181818,
                                              Light=#FAF9F6}"
            HorizontalOptions="Center" StrokeShape="RoundRectangle 12" StrokeThickness="0" VerticalOptions="Center">
        <Border.Resources>
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{AppThemeBinding Dark=#FAF9F6, Light=#1C1917}" />
            </Style>
        </Border.Resources>
        <Border.WidthRequest>
            <OnIdiom Default="350" Desktop="500" />
        </Border.WidthRequest>
        <VerticalStackLayout Spacing="15">
            <Label Padding="0,15,0,0"
                   FontSize="20" HorizontalOptions="Center" Text="Şifre Ekle" VerticalOptions="Start" />
            <uranium:TextField Title="Password Title"
                               Text="{Binding Title}"
                               WidthRequest="200" />
            <uranium:TextField Title="Email or username"
                               Text="{Binding UserName}"
                               WidthRequest="200" />
            <uranium:TextField Title="Password"
                               Text="{Binding Password}"
                               WidthRequest="200" />
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Security" />
                <ProgressBar Progress="{Binding SecurityProgress}" WidthRequest="70" />
                <Label Text="{Binding SecurityStatus}" />
            </HorizontalStackLayout>
            <Button Margin="15,0,15,15"
                    Command="{Binding AddPasswordCommand}"
                    StyleClass="FilledButton" Text="Ekle" />
        </VerticalStackLayout>
    </Border>

</mopups:PopupPage>
